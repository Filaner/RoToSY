<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_geometries>
    <geometry id="sign_plane_geometry" name="sign_plane_geometry">
      <mesh>
        <source id="sign_plane_positions">
          <float_array id="sign_plane_positions_array" count="12">-0.5 -0.5 0 0.5 -0.5 0 0.5 0.5 0 -0.5 0.5 0</float_array>
          <technique_common>
            <accessor source="#sign_plane_positions_array" count="4" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="sign_plane_normals">
          <float_array id="sign_plane_normals_array" count="3">0 0 1</float_array>
          <technique_common>
            <accessor source="#sign_plane_normals_array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="sign_plane_texcoords">
          <float_array id="sign_plane_texcoords_array" count="8">0 0 1 0 1 1 0 1</float_array>
          <technique_common>
            <accessor source="#sign_plane_texcoords_array" count="4" stride="2">
              <param name="S" type="float"/>
              <param name="T" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="sign_plane_vertices">
          <input semantic="POSITION" source="#sign_plane_positions"/>
        </vertices>
        <triangles count="2">
          <input semantic="VERTEX" source="#sign_plane_vertices" offset="0"/>
          <input semantic="NORMAL" source="#sign_plane_normals" offset="1"/>
          <input semantic="TEXCOORD" source="#sign_plane_texcoords" offset="2" set="0"/>
          <p>0 0 0 1 0 1 2 0 2 0 0 0 2 0 2 3 0 3</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="sign_plane" name="sign_plane">
        <instance_geometry url="#sign_plane_geometry"/>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
